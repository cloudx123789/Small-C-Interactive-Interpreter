/* Test 01: 基本算術與運算子優先順序 */
int main() {
    printf("%d\n", 2 + 3 * 4);
    printf("%d\n", (2 + 3) * 4);
    printf("%d\n", 100 / 7);
    printf("%d\n", 100 % 7);
    printf("%d\n", -15 / 4);
    printf("%d\n", -15 % 4);
    printf("%d\n", 2 + 3 * 4 - 8 / 2);
    printf("0x%x\n", 0xFF);
    return 0;
}
